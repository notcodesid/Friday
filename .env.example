# Gemini API Keys (comma-separated for multi-key rotation)
# Add multiple keys to automatically rotate when one is exhausted
# Example: key1,key2,key3
GEMINI_API_KEYS=your_gemini_api_key_1,your_gemini_api_key_2

# Gemini model (default: gemini-2.0-flash)
AI_MODEL=gemini-2.0-flash

# Legacy single key (optional, use GEMINI_API_KEYS instead)
GEMINI_API_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PROJECT_ID=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
NEXT_PUBLIC_DEFAULT_SITE_URL=https://www.tryproven.fun/
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_MERCHANT_WALLET=
